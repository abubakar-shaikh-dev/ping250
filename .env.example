# ─────────────────────────────────────────────────────────────────────────────
# Ping250 environment
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────────────────────

# Public canonical URL — used for canonical tags, OG tags, sitemap and the
# same-origin CSRF check on the API routes.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Access gating: Cloudflare Turnstile (bot-check on verify/send) ──────────
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# For local dev you can use Cloudflare's always-pass test keys:
#   site key:  1x00000000000000000000AA
#   secret:    1x0000000000000000000000000000000AA
# Set NEXT_PUBLIC_TURNSTILE_ENABLED=false to skip the widget entirely (dev only).
NEXT_PUBLIC_TURNSTILE_ENABLED="true"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── Rate limiting: Upstash Redis (per-IP) ───────────────────────────────────
# Create a database at https://console.upstash.com and copy the REST URL/token.
# If these are absent the app falls back to an in-process limiter (fine for
# local dev, NOT for production on serverless — instances don't share memory).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional tuning (requests per minute, per IP).
RATE_LIMIT_VERIFY_PER_MIN="10"
RATE_LIMIT_SEND_PER_MIN="5"

# ── Optional: prefill NON-SECRET defaults into the connection form ──────────
# These are read server-side and passed to the page as initial values only.
# The password is deliberately NOT prefillable from env — a secret placed in an
# env var would be rendered into the page HTML and leaked to the client bundle.
DEFAULT_SMTP_HOST=""
DEFAULT_SMTP_PORT="587"
DEFAULT_SMTP_SECURE="false"
DEFAULT_SMTP_FROM_NAME=""
DEFAULT_SMTP_FROM_EMAIL=""
